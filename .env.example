# tavrn environment variables
# Copy to .env and fill in your values.

# Bartender character (optional — disabled if not set)
OPENAI_API_KEY=

# GIF search in chat (optional — disabled if not set)
KLIPY_API_KEY=

# Bartender web search (optional — DuckDuckGo used as fallback)
EXA_API_KEY=

# SSH port (default: 2222 for dev, 22 for production)
# TAVRN_PORT=2222
